<UserControl x:Class="SID.Designer.Layout.tool_base"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SID.Designer.Layout"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="200">
    <Grid>
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top" Background="Black" Height="30">
                <Label Content="Adicionar" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"></Label>
            </Border>
            <Border Background="Gray">
                <TreeView>
                    <TreeViewItem Header="Base">
                        <StackPanel>
                            <Button Content="Tag"></Button>
                            <Button Content="Rung"></Button>
                            <Button Content="Routine"></Button>
                            <Button Content="Routine" Background="Yellow" Foreground="Black"></Button>
                        </StackPanel>
                    </TreeViewItem>
                </TreeView>
               
            </Border>
        </DockPanel>
        
    </Grid>
</UserControl>
