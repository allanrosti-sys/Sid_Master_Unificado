<UserControl x:Class="SID.Designer.Layout.Main"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SID.Designer.Layout"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <DockPanel LastChildFill="True">
            <Border Background="Black" Height="30" DockPanel.Dock="Top">
                <Label x:Name="Header" Height="30" HorizontalAlignment="Center" Content="Titulo da vizualização" Foreground="White" ></Label>
            </Border>
            <Border >
                <DockPanel x:Name="MainViewer" Background="White"></DockPanel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
