<UserControl xmlns:ToolBox="clr-namespace:SID.Designer.ToolBox"  
             x:Class="SID.Designer.Layout.Manager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SID.Designer.Layout"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="300">

    <Grid>
        <DockPanel LastChildFill="True">
            <DockPanel Background="AliceBlue" Height="30" DockPanel.Dock="Top" LastChildFill="True">
                <Label Content="Gerenciador" Foreground="Black" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                <Border>
                    <Rectangle Height="10" >
                        <Rectangle.Fill>
                            <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                                <GradientStop Color="White" Offset="0.01"/>
                                <GradientStop Color="#FF807878" Offset="0.502"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Border>
            </DockPanel>
            <Border Background="DarkGray" DockPanel.Dock="Bottom" Height="100">
                <Label x:Name="Info" Content="Informação"></Label>
            </Border>
            <Border Background="Gray">
                <TreeView x:Name="main" Background="AliceBlue">



                </TreeView>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
