  <Routines>
    <Routine Name="ConnIn_Act" Type="RLL">
      <RLLContent>
        <Rung Number="0" Type="N">
          <Comment>
            <![CDATA[*** Activations ***

Line valve]]>
          </Comment>
          <Text>
            <![CDATA[XIC(Phase_XferIn.Ctrl.Running)XIC(ProdUnit_BusData.Ctrl.Prog.ProgStat.MaterialRequest)XIC(TankUnit_BusData.Ctrl.Prog.ProgStat.MaterialOut)OTL(CM_ManifoldValve.In_Main);]]>
          </Text>
        </Rung>
      </RLLContent>
    </Routine>
    <Routine Name="ConnIn_Alm" Type="RLL">
      <RLLContent>
        <Rung Number="0" Type="N">
          <Comment>
            <![CDATA[*** Alarms ***]]>
          </Comment>
          <Text>
            <![CDATA[NOP();]]>
          </Text>
        </Rung>
      </RLLContent>
    </Routine>
    <Routine Name="ConnIn_Coord" Type="RLL">
      <RLLContent>
        <Rung Number="0" Type="N">
          <Comment>
            <![CDATA[Tetra PlantMaster template library

Function: General connection coordination structure
Version: 6.1.00_01

Created by: Niklas Einarsson
Modified by: Niklas Einarsson
Last updated date: 2008-03-20

Inputs:
Connection status and commands
Bus interface line and tank

Outputs:
Updated connection status
Updated bus interfacecs
Control module commands

Note:
---

Unit sections:
Allocation
Bus coordination input
User interlocks
User running faults
Execution of internal functions
Alarm summary
Bus coordination output]]>
          </Comment>
          <Text>
            <![CDATA[NOP();]]>
          </Text>
        </Rung>
        <Rung Number="1" Type="N">
          <Comment>
            <![CDATA[*** Allocation ***

]]>
          </Comment>
          <Text>
            <![CDATA[_STD_UN_Alloc(ConnIn_Coord.Alloc,0);]]>
          </Text>
        </Rung>
        <Rung Number="2" Type="N">
          <Comment>
            <![CDATA[*** Bus coordination ***

Input]]>
          </Comment>
          <Text>
            <![CDATA[_STD_PC_BusConn_In(_STD_PC_BusConn_In,ProdUnit_BusData,TankUnit_BusData,ConnIn_Coord,Phase_XferIn);]]>
          </Text>
        </Rung>
        <Rung Number="3" Type="N">
          <Comment>
            <![CDATA[*** User interlocks ***

Initialize Interlock conditions]]>
          </Comment>
          <Text>
            <![CDATA[_STD_PH_IntlkInit(Phase_XferIn.Cond.IntlkInit,Phase_XferIn.Ctrl.Interlock);]]>
          </Text>
        </Rung>
        <Rung Number="4" Type="N">
          <Comment>
            <![CDATA[Incorrect material ID
]]>
          </Comment>
          <Text>
            <![CDATA[AFI()_STD_PH_Intlk(Phase_XferIn.Cond.Intlk[3],3,Phase_XferIn.Cond.IntlkInit,Phase_XferIn.Ctrl.Interlock,_TMP_PH_CondTexts.IncorrectMaterialID,1,Phase_XferIn.Ctrl.Oper);]]>
          </Text>
        </Rung>
        <Rung Number="5" Type="N">
          <Comment>
          </Comment>
          <Text>
            <![CDATA[XIC(CM_ManifoldValve.Out_ManMode)_STD_PH_Intlk(Phase_XferIn.Cond.Intlk[4],4,Phase_XferIn.Cond.IntlkInit,Phase_XferIn.Ctrl.Interlock,_TMP_PH_CondTexts.ManualActivationDeactivation,1,Phase_XferIn.Ctrl.Oper);]]>
          </Text>
        </Rung>
        <Rung Number="6" Type="N">
          <Comment>
            <![CDATA[*** User running faults ***

Initialize RunningFault conditions]]>
          </Comment>
          <Text>
            <![CDATA[_STD_PH_RunFltInit(Phase_XferIn.Cond.RunFltInit,Phase_XferIn.Ctrl.RunningFault);]]>
          </Text>
        </Rung>
        <Rung Number="7" Type="N">
          <Comment>
            <![CDATA[Valve fault]]>
          </Comment>
          <Text>
            <![CDATA[XIC(CM_ManifoldValve.Out_GenAlmOn)_STD_PH_RunFlt(Phase_XferIn.Cond.RunFlt[1],1,Phase_XferIn.Cond.RunFltInit,Phase_XferIn.Ctrl.RunningFault,Phase_XferIn.ParCategory.EventInfoCauseID,_TMP_PH_CondTexts.ValveFault,0,Phase_XferIn.Ctrl.Reset);]]>
          </Text>
        </Rung>
        <Rung Number="8" Type="N">
          <Comment>
            <![CDATA[*** Execution of internal functions ***

Alarms]]>
          </Comment>
          <Text>
            <![CDATA[JSR(ConnIn_Alm,0);]]>
          </Text>
        </Rung>
        <Rung Number="9" Type="N">
          <Comment>
            <![CDATA[Transfer]]>
          </Comment>
          <Text>
            <![CDATA[_USR_PH_Phase_XferIn(_USR_PH_Phase_XferIn,Phase_XferIn,ProdUnit_BusData,TankUnit_BusData,ConnIn_Coord,_STD_EL_DBBufferArea,_STD_EL_LogBuffer,_TMP_PH_CondTexts,_TMP_PH_CmdCtrlIDs,_TMP_GF_MaterialSeparationRulesConfig,0,0);]]>
          </Text>
        </Rung>
        <Rung Number="10" Type="N">
          <Comment>
            <![CDATA[Activations]]>
          </Comment>
          <Text>
            <![CDATA[AFI()JSR(ConnIn_Act,0);]]>
          </Text>
        </Rung>
        <Rung Number="11" Type="N">
          <Comment>
            <![CDATA[*** Alarm summary ***]]>
          </Comment>
          <Text>
            <![CDATA[XIC(CM_ManifoldValve.Out_GenAlmOn)OTE(ConnIn_Coord.SumAlarm);]]>
          </Text>
        </Rung>
        <Rung Number="12" Type="N">
          <Comment>
            <![CDATA[*** Bus coordination ***

Output]]>
          </Comment>
          <Text>
            <![CDATA[_STD_PC_BusConn_Out(_STD_PC_BusConn_Out,ProdUnit_BusData,TankUnit_BusData,ConnIn_Coord,Phase_XferIn);]]>
          </Text>
        </Rung>
      </RLLContent>
    </Routine>
    <Routine Name="Main" Type="RLL">
      <RLLContent>
        <Rung Number="0" Type="N">
          <Comment>
            <![CDATA[The Main routine is used to execute the Coordinator only.
All other routines in the program are executed by the Coordinator.
The reason for that is to allow the user to copy all routines from one program to another
without the need to reconfigure the Main routine in each program. ]]>
          </Comment>
          <Text>
            <![CDATA[JSR(ConnIn_Coord,0);]]>
          </Text>
        </Rung>
      </RLLContent>
    </Routine>
  </Routines>
</Program>