    </Tag>
    <Tag Name="ProdUnit_BusData" TagType="Alias" AliasFor="@ProdUnit_Unit_Coord.Dest" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[@ProdUnit_Unit_Coord]]>
      </Description>
    </Tag>
    <Tag Name="TankUnit_BusData" TagType="Alias" AliasFor="@TankUnit_Unit_Coord.Fill" ExternalAccess="Read/Write">
