<UserControl x:Class="SID_APP.Layout.manager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SID_APP.Layout"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="200">
    <Grid>
        <DockPanel LastChildFill="True">
            <Border Background="Black" Height="30" DockPanel.Dock="Top">
                <Label Content="Gerenciador" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" > </Label>
            </Border>
            <Border Background="DarkGray" DockPanel.Dock="Bottom" Height="100">
                <Label x:Name="Label1" Content="dddd"></Label>
            </Border>
            <Border Background="Gray">
                <TreeView Background="AliceBlue">
                    <TreeViewItem Header="Projeto" >
                    </TreeViewItem >
                    <TreeViewItem Header="Tags">
                    </TreeViewItem >
                    <TreeViewItem Header="Rungs">
                    </TreeViewItem>
                    <TreeViewItem Header="Routines">
                    </TreeViewItem>
                    <TreeViewItem Header="Programs">
                    </TreeViewItem>
                   
                </TreeView>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
