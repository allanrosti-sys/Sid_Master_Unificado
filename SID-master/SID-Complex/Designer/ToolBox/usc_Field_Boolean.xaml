<UserControl x:Class="SID.Complex.Designer.ToolBox.usc_Field_Boolean"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SID.Complex.Designer.ToolBox"
             mc:Ignorable="d" d:DesignWidth="250">
    <Grid>
        <Border Margin ="10,5,10,5" Background="GhostWhite" BorderBrush="Gainsboro" BorderThickness="1" CornerRadius="5">
            <Border Margin="0,5,0,0" >
                <StackPanel  >
                    <Label Content="Texto" x:Name="lb_Name" Margin="5,0,0,0"></Label>
                    <CheckBox x:Name="cbx_Value" Margin="10,0,10,10" Checked="Cbx_Value_Checked" Unchecked="Cbx_Value_Checked"></CheckBox>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
