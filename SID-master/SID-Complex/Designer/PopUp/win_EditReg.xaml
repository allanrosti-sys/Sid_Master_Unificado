<Window x:Class="SID.Complex.Designer.PopUp.win_EditReg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SID.Complex.Designer.PopUp"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="win_CM" Height="600" Width="400" WindowStartupLocation="CenterScreen">
    <Grid >
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Bottom">
                <Button x:Name="btn_Save" Margin="50,10,50,10" Content="Salvar" Click="Btn_Save_Click" />
            </Border>
            <ScrollViewer>
                <StackPanel x:Name="main" >

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
